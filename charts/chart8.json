{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "background": "#1f1f1f",
  "config": {
    "view": {"stroke": null},
    "font": "DM Sans, sans-serif",
    "legend": {
      "labelColor": "#9a9590",
      "titleColor": "#9a9590"
    }
  },
  "projection": {"type": "mercator", "center": [134, -28], "scale": 700},
  "layer": [
    {
      "data": {
        "url": "/charts/aus-states.json",
        "format": {"type": "json", "property": "features"}
      },
      "mark": {"type": "geoshape", "fill": "#2a2a2a", "stroke": "#444", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "/charts/aus-states.json",
        "format": {"type": "json", "property": "features"}
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {
              "values": [
                {"state": "New South Wales", "arrivals": 169990},
                {"state": "Victoria", "arrivals": 149490},
                {"state": "Queensland", "arrivals": 97370},
                {"state": "South Australia", "arrivals": 27160},
                {"state": "Western Australia", "arrivals": 65310},
                {"state": "Tasmania", "arrivals": 4750},
                {"state": "Northern Territory", "arrivals": 5250},
                {"state": "Australian Capital Territory", "arrivals": 9480}
              ]
            },
            "key": "state",
            "fields": ["arrivals", "state"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "#1f1f1f", "strokeWidth": 1},
      "encoding": {
        "color": {
          "field": "arrivals",
          "type": "quantitative",
          "scale": {"scheme": "blues"},
          "legend": {
            "title": "Arrivals 2024–25",
            "labelExpr": "(datum.value / 1000) + 'k'",
            "orient": "bottom-right",
            "direction": "horizontal",
            "gradientLength": 200,
            "labelColor": "#9a9590",
            "titleColor": "#9a9590"
          }
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "arrivals", "title": "Arrivals", "format": ","}
        ]
      }
    }
  ]
}