{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 750,
  "height": 400,
  "background": "#ffffff",
  "config": {
    "view": {
      "stroke": null
    }
  },
  "projection": {
    "type": "naturalEarth1",
    "rotate": [
      -10,
      0,
      0
    ]
  },
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/vega-datasets@2/data/world-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "transform": [
        {
          "filter": "datum.id !== 10"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#f1f5f9",
        "stroke": "#cbd5e1",
        "strokeWidth": 0.5
      }
    },
    {
