        ]
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "https://cdn.jsdelivr.net/npm/vega-datasets@2/data/world-110m.json",
              "format": {
                "type": "topojson",
                "feature": "countries"
              }
            },
            "key": "id"
          },
          "as": "geo"
        }
      ],
      "params": [
        {
          "name": "highlight",
          "select": {
            "type": "point",
            "on": "click",
            "fields": [
              "country"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape"
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "arrivals",
          "type": "quantitative",
          "scale": {
            "scheme": "blues",
            "domain": [
              1000,
              80000
            ]
          },
          "legend": {
            "title": "Arrivals 2024–25",
            "labelExpr": "(datum.value/1000) + 'k'",
            "orient": "right",
            "direction": "vertical",
            "gradientLength": 150,
            "values": [
              1000,
              20000,
              40000,
              60000,
              80000
            ]
          }
        },
        "opacity": {
          "condition": {
            "param": "highlight",
            "empty": true,
            "value": 1
          },
          "value": 0.2
        },
        "stroke": {
          "condition": {
            "param": "highlight",
            "empty": false,
            "value": "#111827"
          },
          "value": "#ffffff"
        },
        "strokeWidth": {
          "condition": {
            "param": "highlight",
            "empty": false,
            "value": 2
          },
          "value": 0.5
        },
        "tooltip": [
          {
            "field": "country",
            "title": "Country"
          },
          {
            "field": "arrivals",
            "title": "Arrivals",
            "format": ","
          }
        ]
      }
    }
  ]
}