      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "https://cdn.jsdelivr.net/npm/vega-datasets@2/data/world-110m.json",
              "format": {"type": "topojson", "feature": "countries"}
            },
            "key": "id"
          },
          "as": "geo"
        }
      ],
      "mark": {"type": "geoshape", "stroke": "#ffffff", "strokeWidth": 0.5},
      "encoding": {
        "shape": {"field": "geo", "type": "geojson"},
        "color": {
          "field": "arrivals",
          "type": "quantitative",
          "scale": {
            "scheme": "blues",
            "domain": [1000, 80000]
          },
          "legend": {
            "title": "Arrivals 2024–25",
            "labelExpr": "(datum.value/1000) + 'k'",
            "orient": "right",
            "direction": "vertical",
            "gradientLength": 150
          }
        },
        "tooltip": [
          {"field": "country", "title": "Country"},
          {"field": "arrivals", "title": "Arrivals", "format": ","}
        ]
      }
    }
